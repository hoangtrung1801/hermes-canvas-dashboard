# Hermes Canvas gateway
CANVAS_GATEWAY_PORT=8787
CANVAS_GATEWAY_DATA_DIR=data

# Frontend development and production static server
APP_HOST=0.0.0.0
APP_PORT=5173
DIST_DIR=dist

# Vite client configuration
VITE_CANVAS_GATEWAY_URL=ws://localhost:8787/canvas?canvasId=canvas_001&role=bridge
VITE_TLDRAW_SYNC_URL=ws://localhost:8787/sync

# Demo Hermes client
HERMES_CANVAS_URL=ws://localhost:8787/canvas?canvasId=canvas_001&role=hermes
HERMES_CANVAS_TIMEOUT_MS=5000

# Canvas dashboard plugin/tooling
CANVAS_DASHBOARD_URL=ws://localhost:8787/canvas?canvasId=canvas_001&role=hermes
CANVAS_DASHBOARD_CANVAS_ID=canvas_001
CANVAS_DASHBOARD_TIMEOUT_MS=5000

# Python AI canvas agent (OpenAI-compatible, tool-calling model required)
AI_MODEL_BASE_URL=http://localhost:11434/v1
AI_MODEL_API_KEY=replace-me
AI_MODEL_NAME=replace-with-tool-calling-model
AI_MODEL_TEMPERATURE=0.1
AI_MODEL_TIMEOUT_SECONDS=60
AI_DATABASE_PATH=data/agent-chat.sqlite
AI_SERVICE_HOST=127.0.0.1
AI_SERVICE_PORT=8000
AI_ALLOWED_ORIGINS=http://localhost:5173
CANVAS_GATEWAY_URL=ws://localhost:8787/canvas
CANVAS_REQUEST_TIMEOUT_SECONDS=8
CANVAS_REQUEST_RETRY_COUNT=2
AI_MAX_TOOL_CALLS_PER_TURN=12
AI_MAX_ACTIONS_PER_TURN=40
AI_MAX_CANVAS_CONTEXT_CHARS=24000
VITE_AI_SERVICE_URL=http://127.0.0.1:8000
